<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      width: 100%;
      background-color: #f4f4f4;
      font-family: Arial, sans-serif;
      font-size: 14px;
      line-height: 1.6;
      color: #565656;
    }
    .email-wrapper {
      width: 100%;
      padding: 40px 0;
      background-color: #f4f4f4;
    }
    .email-content {
      background-color: #ffffff;
      border: 1px solid #ddd;
      max-width: 600px;
      margin: 0 auto;
      border-radius: 8px;
      overflow: hidden;
    }
    .email-header {
      text-align: center;
      padding: 30px 20px;
      background-color: #1a1a2e;
    }
    .email-header h1 {
      color: #ffffff;
      margin: 0;
      font-size: 22px;
      letter-spacing: 2px;
    }
    .email-body {
      padding: 30px 25px;
    }
    .email-body p {
      margin: 0 0 16px;
    }
    .email-footer {
      text-align: center;
      padding: 20px;
      background-color: #f9f9f9;
      font-size: 12px;
      color: #999;
    }
  </style>
</head>
<body>
  <div class="email-wrapper">
    <table class="email-content" cellpadding="0" cellspacing="0">
      <tr>
        <td class="email-header">
          <h1>MAISON GANSOU</h1>
        </td>
      </tr>
      <tr>
        <td class="email-body">
          <div style="white-space: pre-wrap;">{{ content }}</div>
        </td>
      </tr>
      <tr>
        <td class="email-footer">
          <p>&copy; {{ year }} Maison GANSOU. Tous droits réservés.</p>
        </td>
      </tr>
    </table>
  </div>
</body>
</html>