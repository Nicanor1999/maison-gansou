{% extends "layouts/layout.njk" %}

{% block content %}
  <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <div style="background-color: #dc3545; color: white; padding: 20px; border-radius: 5px 5px 0 0;">
      <h1 style="margin: 0; font-size: 24px;">Security Alert</h1>
    </div>
    
    <div style="background-color: #f8f9fa; padding: 30px; border: 1px solid #dee2e6; border-top: none; border-radius: 0 0 5px 5px;">
      {% if firstName and firstName.trim() and lastName and lastName.trim() %}
      <p style="font-size: 16px; color: #212529;">Hello {{ firstName }} {{ lastName }}</p>
      {% elif firstName and firstName.trim() %}
      <p style="font-size: 16px; color: #212529;">Hello {{ firstName }}</p>
      {% else %}
      <p style="font-size: 16px; color: #212529;">Hello</p>
      {% endif %}
      
      <div style="background-color: #fff3cd; border-left: 4px solid #ffc107; padding: 15px; margin: 20px 0;">
        <h2 style="margin: 0 0 10px 0; color: #856404; font-size: 18px;">{{ alertType }}</h2>
        <p style="margin: 0; color: #856404;">{{ alertMessage }}</p>
      </div>
      
      <p style="font-size: 14px; color: #495057;">
        We detected the following activity on your account:
      </p>
      
      <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <tr style="background-color: #e9ecef;">
          <td style="padding: 10px; border: 1px solid #dee2e6; font-weight: bold;">Time</td>
          <td style="padding: 10px; border: 1px solid #dee2e6;">{{ timestamp }}</td>
        </tr>
        <tr>
          <td style="padding: 10px; border: 1px solid #dee2e6; font-weight: bold;">IP Address</td>
          <td style="padding: 10px; border: 1px solid #dee2e6;">{{ ipAddress }}</td>
        </tr>
        <tr style="background-color: #e9ecef;">
          <td style="padding: 10px; border: 1px solid #dee2e6; font-weight: bold;">Device</td>
          <td style="padding: 10px; border: 1px solid #dee2e6;">{{ device }}</td>
        </tr>
        <tr>
          <td style="padding: 10px; border: 1px solid #dee2e6; font-weight: bold;">Location</td>
          <td style="padding: 10px; border: 1px solid #dee2e6;">{{ location }}</td>
        </tr>
        {% if email and email.trim() %}
        <tr style="background-color: #e9ecef;">
          <td style="padding: 10px; border: 1px solid #dee2e6; font-weight: bold;">Email</td>
          <td style="padding: 10px; border: 1px solid #dee2e6;">{{ email }}</td>
        </tr>
        {% endif %}
        {% if phoneNumber and phoneNumber.trim() %}
        <tr style="background-color: #e9ecef;">
          <td style="padding: 10px; border: 1px solid #dee2e6; font-weight: bold;">Phone Number</td>
          <td style="padding: 10px; border: 1px solid #dee2e6;">{{ phoneNumber }}</td>
        </tr>
        {% endif %}
      </table>
      
      <div style="background-color: #f8d7da; border-left: 4px solid #dc3545; padding: 15px; margin: 20px 0;">
        <p style="margin: 0; color: #721c24; font-weight: bold;">
          If this was not you, please secure your account immediately by changing your password and reviewing your security settings.
        </p>
      </div>
      
      <p style="font-size: 14px; color: #495057;">
        If you recognize this activity, you can safely ignore this email.
      </p>
      
      <p style="font-size: 14px; color: #212529; margin-top: 30px;">
        Kind Regards,<br>
        OrangCode
      </p>
    </div>
  </div>
{% endblock %}