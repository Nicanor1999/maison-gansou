<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confirmation de paiement</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      width: 100%;
      background-color: #f4f4f4;
      font-family: Arial, sans-serif;
      font-size: 14px;
      line-height: 1.6;
      color: #565656;
    }
    .email-wrapper {
      width: 100%;
      padding: 40px 0;
      background-color: #f4f4f4;
    }
    .email-content {
      background-color: #ffffff;
      border: 1px solid #ddd;
      max-width: 600px;
      margin: 0 auto;
      border-radius: 8px;
      overflow: hidden;
    }
    .email-header {
      text-align: center;
      padding: 30px 20px;
      background-color: #1a1a2e;
    }
    .email-header h1 {
      color: #ffffff;
      margin: 0;
      font-size: 22px;
      letter-spacing: 2px;
    }
    .email-body {
      padding: 30px 25px;
    }
    .email-body h2 {
      color: #1a1a2e;
      margin: 0 0 20px;
      font-size: 20px;
    }
    .email-body p {
      margin: 0 0 16px;
    }
    .order-table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }
    .order-table th,
    .order-table td {
      border: 1px solid #e0e0e0;
      padding: 12px 15px;
      text-align: left;
      font-size: 14px;
    }
    .order-table th {
      background-color: #f9f9f9;
      font-weight: bold;
      color: #1a1a2e;
      width: 40%;
    }
    .email-footer {
      text-align: center;
      padding: 20px;
      background-color: #f9f9f9;
      font-size: 12px;
      color: #999;
    }
    @media (max-width: 600px) {
      .email-content {
        width: 95% !important;
      }
      .email-body {
        padding: 20px 15px;
      }
    }
  </style>
</head>
<body>
  <div class="email-wrapper">
    <table class="email-content" cellpadding="0" cellspacing="0">
      <!-- Header -->
      <tr>
        <td class="email-header">
          <h1>MAISON GANSOU</h1>
        </td>
      </tr>
      <!-- Body -->
      <tr>
        <td class="email-body">
          <h2>Confirmation de paiement</h2>

          <p>Bonjour {{ clientName }},</p>

          <p>
            Nous vous confirmons que votre paiement a bien été reçu. Voici le récapitulatif de votre réservation :
          </p>

          <table class="order-table">
            <tr>
              <th>Réservation</th>
              <td>#{{ reservationId }}</td>
            </tr>
            <tr>
              <th>Logement</th>
              <td>{{ offerTitle }}</td>
            </tr>
            <tr>
              <th>Date d'arrivée</th>
              <td>{{ startDate }}</td>
            </tr>
            <tr>
              <th>Date de départ</th>
              <td>{{ arrivalDate }}</td>
            </tr>
            <tr>
              <th>Montant payé</th>
              <td><strong>{{ amount }} FCFA</strong></td>
            </tr>
            <tr>
              <th>Transaction</th>
              <td>{{ transactionId }}</td>
            </tr>
          </table>

          <p>
            Si vous avez des questions concernant votre réservation, n'hésitez pas à nous contacter.
          </p>

          <p>Cordialement,<br><strong>Maison GANSOU</strong></p>
        </td>
      </tr>
      <!-- Footer -->
      <tr>
        <td class="email-footer">
          <p>&copy; {{ year }} Maison GANSOU. Tous droits réservés.</p>
        </td>
      </tr>
    </table>
  </div>
</body>
</html>