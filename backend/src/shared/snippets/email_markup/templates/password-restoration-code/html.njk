{% extends "layouts/layout.njk" %}

{% block content %}
  <div>
    <h3>Password Restoration</h3>

    <p>Hello {{ fullName }}</p>

    <p>
      We received a request to reset the password for your account on OrangCode. Use the following code to reset your password:
    </p>

    <p>
      <strong>Restoration Code: {{ code }}</strong>
    </p>

    <p>
      Please note that this code will expire in {{ expiryMinutes }} minutes. If you did not request this, please ignore this email.
    </p>

    <p>Kind Regards,<br> OrangCode</p>
  </div>
{% endblock %}